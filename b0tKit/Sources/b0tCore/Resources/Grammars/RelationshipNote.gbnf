char ::= [^"\\\x7F\x00-\x1F] | [\\] (["\\bfnrt] | "u" [0-9a-fA-F]{4})
name-kv ::= "\"name\"" space ":" space string
notes-kv ::= "\"notes\"" space ":" space string
relation-kv ::= "\"relation\"" space ":" space string
root ::= "{" space name-kv "," space relation-kv "," space notes-kv "}" space
space ::= | " " | "\n"{1,2} [ \t]{0,20}
string ::= "\"" char* "\"" space
